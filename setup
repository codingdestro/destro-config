#!/bin/bash

sudo apt-get update
sudo apt-get upgrade -y

sudo apt-get install git curl unzip wget fontconfig net-tools vim nano zsh 

curl -fLo "Hack.zip" https://github.com/ryanoasis/nerd-fonts/releases/download/v2.2.2/Hack.zip

mkdir -p ~/.local/share/fonts
unzip Hack.zip -d ~/.local/share/fonts

fc-cache -fv
fc-list | grep "Hack"

echo "installing the node.js"
curl -fsSL https://deb.nodesource.com/setup_current.x | sudo -E bash -
sudo apt-get install -y nodejs
node -v
npm -v

# Neovim
echo "install Neovim"
sudo add-apt-repository ppa:neovim-ppa/stable
sudo apt update
sudo apt install neovim
nvim --version

cp ./zsh/.zshrc ~/.zshrc


